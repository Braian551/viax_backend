APP_ENV=production
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Viax
RATE_LIMIT_IP_PER_HOUR=15
RATE_LIMIT_USER_PER_HOUR=5
RATE_LIMIT_BLOCK_MINUTES=120
RATE_LIMIT_SECRET=change-this-to-a-random-long-string

# Pricing hibrido: usuario paga precio upfront, tracking conserva precio real.
UPFRONT_PRICING_ENABLED=false
UPFRONT_PRICING_MARGIN_PROTECTION=true
UPFRONT_PRICING_MAX_LOSS_RATIO=0.20

# CORS + seguridad global
CORS_ALLOWED_ORIGINS=https://viaxcol.online,https://www.viaxcol.online
CORS_STRICT_MODE=true
GLOBAL_RATE_LIMIT_ENABLED=true

# Fraude conductor
DRIVER_FRAUD_DETECTION_ENABLED=true

# Bypass QA (codigo 8052)
TEST_BYPASS_ENABLED=false
TEST_BYPASS_RATE_LIMIT_MAX=5
TEST_BYPASS_RATE_LIMIT_WINDOW_SEC=300
TEST_BYPASS_ALLOWED_IPS=

# Servicios legacy/new
USE_NEW_SERVICES=true

# Auth tokens
AUTH_ACCESS_TOKEN_TTL=3600
AUTH_REFRESH_TOKEN_TTL=1209600
