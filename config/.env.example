# Backend Configuration for Viax
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viax
DB_USER=postgres
DB_PASS=your_database_password_here

# ===========================================
# Mapbox (https://account.mapbox.com/)
# ===========================================
MAPBOX_PUBLIC_TOKEN=your_mapbox_public_token_here
MAPBOX_SECRET_TOKEN=your_mapbox_secret_token_here

# TomTom (https://developer.tomtom.com/)
TOMTOM_API_KEY=your_tomtom_api_key_here

# Google Places (https://console.cloud.google.com/)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Nominatim (OpenStreetMap)
NOMINATIM_USER_AGENT=Viax App
NOMINATIM_EMAIL=your-email@example.com

# ===========================================
# Website / Frontend (for share links)
# ===========================================
WEBSITE_URL=http://viax.app

# Quota Limits (optional overrides)
MAPBOX_MONTHLY_LIMIT=100000
MAPBOX_ROUTING_LIMIT=100000
TOMTOM_DAILY_LIMIT=2500

# Cloudflare R2 Storage (https://dash.cloudflare.com/r2)
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=uploadviax

# ===========================================
# Seguridad de datos financieros sensibles
# ===========================================
# Clave para cifrado AES-256 de números de cuenta.
# Usa una cadena larga y única por entorno.
SENSITIVE_DATA_KEY=change_this_to_a_long_random_secret_key

# ===========================================
# Pricing hibrido (upfront + real)
# ===========================================
# false: flujo legacy (precio final dinamico)
# true: precio fijo upfront con recalc por reglas
UPFRONT_PRICING_ENABLED=false
UPFRONT_PRICING_MARGIN_PROTECTION=true
UPFRONT_PRICING_MAX_LOSS_RATIO=0.20

# CORS centralizado
CORS_ALLOWED_ORIGINS=https://viaxcol.online,https://www.viaxcol.online,capacitor://localhost,http://localhost:3000
CORS_STRICT_MODE=true

# Rate limit global
GLOBAL_RATE_LIMIT_ENABLED=true

# Deteccion de fraude de ruta
DRIVER_FRAUD_DETECTION_ENABLED=true

# Migracion progresiva de servicios
USE_NEW_SERVICES=true

# Endurecimiento auth
AUTH_ACCESS_TOKEN_TTL=3600
AUTH_REFRESH_TOKEN_TTL=1209600
