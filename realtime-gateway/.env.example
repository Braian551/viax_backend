# Viax Realtime Gateway — Variables de entorno
# Copiar a .env y ajustar valores

NODE_ENV=production
WS_PORT=9100

# Redis (mismas credenciales que el backend PHP)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# SSL (opcional — si se usa reverse proxy como Nginx, no es necesario)
WS_SSL_ENABLED=false
WS_SSL_KEY=
WS_SSL_CERT=

# Logging
LOG_LEVEL=info
